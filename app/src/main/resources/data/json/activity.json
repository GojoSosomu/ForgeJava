        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "2. Which keyword is used to implement an interface?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. implements" }, { "type": "TEXT", "text": "B. extends" }, { "type": "TEXT", "text": "C. inherits" }, { "type": "TEXT", "text": "D. using" } ], "correctAnswerIndex": 0 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "3. A class can implement multiple interfaces." } ], "values": { "options": [ { "type": "TEXT", "text": "A. True" }, { "type": "TEXT", "text": "B. False" } ], "correctAnswerIndex": 0 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "4. Variables in an interface are public, static, and final by default." } ], "values": { "options": [ { "type": "TEXT", "text": "A. True" }, { "type": "TEXT", "text": "B. False" } ], "correctAnswerIndex": 0 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "5. What is a method with a signature but no body called?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. Private method" }, { "type": "TEXT", "text": "B. Static method" }, { "type": "TEXT", "text": "C. Abstract method" }, { "type": "TEXT", "text": "D. Final method" } ], "correctAnswerIndex": 2 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "6. Which keyword allows an interface to have a method body (Java 8+)?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. static" }, { "type": "TEXT", "text": "B. default" }, { "type": "TEXT", "text": "C. abstract" }, { "type": "TEXT", "text": "D. protected" } ], "correctAnswerIndex": 1 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "7. Abstract classes focus on 'what' an object is, not 'how' it works." } ], "values": { "options": [ { "type": "TEXT", "text": "A. True" }, { "type": "TEXT", "text": "B. False" } ], "correctAnswerIndex": 0 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "8. Interfaces define a 'contract' that classes must follow." } ], "values": { "options": [ { "type": "TEXT", "text": "A. True" }, { "type": "TEXT", "text": "B. False" } ], "correctAnswerIndex": 0 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "9. Which type is used for 'can-do' relationships among unrelated classes?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. Class" }, { "type": "TEXT", "text": "B. Package" }, { "type": "TEXT", "text": "C. Interface" }, { "type": "TEXT", "text": "D. Static block" } ], "correctAnswerIndex": 2 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "10. An interface can extend another interface." } ], "values": { "options": [ { "type": "TEXT", "text": "A. True" }, { "type": "TEXT", "text": "B. False" } ], "correctAnswerIndex": 0 } }
      ]

        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "2. Which interface ensures that no duplicate elements are stored?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. Set" }, { "type": "TEXT", "text": "B. List" }, { "type": "TEXT", "text": "C. Map" }, { "type": "TEXT", "text": "D. Queue" } ], "correctAnswerIndex": 0 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "3. A Map stores data in key-value pairs." } ], "values": { "options": [ { "type": "TEXT", "text": "A. True" }, { "type": "TEXT", "text": "B. False" } ], "correctAnswerIndex": 0 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "4. Which method is used to add an item to an ArrayList?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. put()" }, { "type": "TEXT", "text": "B. insert()" }, { "type": "TEXT", "text": "C. push()" }, { "type": "TEXT", "text": "D. add()" } ], "correctAnswerIndex": 3 } },

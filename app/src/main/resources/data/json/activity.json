  "A-012": {
    "problem": {
      "type": "QUESTIONNAIRE",
      "instructions": [ { "type": "TEXT", "text": "Assessment 12: Exceptions" } ],
      "questions": [
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "1. Which block is used for code that might throw an exception?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. catch" }, { "type": "TEXT", "text": "B. throw" }, { "type": "TEXT", "text": "C. try" }, { "type": "TEXT", "text": "D. finally" } ], "correctAnswerIndex": 2 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "2. Which block is guaranteed to run even if an error occurs?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. try" }, { "type": "TEXT", "text": "B. catch" }, { "type": "TEXT", "text": "C. error" }, { "type": "TEXT", "text": "D. finally" } ], "correctAnswerIndex": 3 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "3. Unchecked exceptions are subclasses of RuntimeException." } ], "values": { "options": [ { "type": "TEXT", "text": "A. True" }, { "type": "TEXT", "text": "B. False" } ], "correctAnswerIndex": 0 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "4. Which keyword manually triggers an exception?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. throw" }, { "type": "TEXT", "text": "B. throws" }, { "type": "TEXT", "text": "C. error" }, { "type": "TEXT", "text": "D. signal" } ], "correctAnswerIndex": 0 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "5. Which keyword declares that a method might throw a checked exception?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. throw" }, { "type": "TEXT", "text": "B. catch" }, { "type": "TEXT", "text": "C. final" }, { "type": "TEXT", "text": "D. throws" } ], "correctAnswerIndex": 3 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "6. A try block must be followed by either a catch or a finally block." } ], "values": { "options": [ { "type": "TEXT", "text": "A. True" }, { "type": "TEXT", "text": "B. False" } ], "correctAnswerIndex": 0 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "7. What is the root class for all Errors and Exceptions?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. Object" }, { "type": "TEXT", "text": "B. Throwable" }, { "type": "TEXT", "text": "C. Error" }, { "type": "TEXT", "text": "D. Master" } ], "correctAnswerIndex": 1 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "8. Catching 'Exception' will catch all its subclasses as well." } ], "values": { "options": [ { "type": "TEXT", "text": "A. True" }, { "type": "TEXT", "text": "B. False" } ], "correctAnswerIndex": 0 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "9. Which structure auto-closes resources like files?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. while loop" }, { "type": "TEXT", "text": "B. try-with-resources" }, { "type": "TEXT", "text": "C. static block" }, { "type": "TEXT", "text": "D. interface" } ], "correctAnswerIndex": 1 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "10. Checked exceptions are ignored by the compiler." } ], "values": { "options": [ { "type": "TEXT", "text": "A. True" }, { "type": "TEXT", "text": "B. False" } ], "correctAnswerIndex": 1 } }
      ]
    }
  },
  "A-013": {
    "problem": {
      "type": "QUESTIONNAIRE",
      "instructions": [ { "type": "TEXT", "text": "Assessment 13: Concurrency" } ],
      "questions": [
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "1. Which method starts a new thread?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. run()" }, { "type": "TEXT", "text": "B. start()" } ], "correctAnswerIndex": 1 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "2. Which keyword prevents multiple threads from accessing code at once?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. volatile" }, { "type": "TEXT", "text": "B. synchronized" }, { "type": "TEXT", "text": "C. lock" }, { "type": "TEXT", "text": "D. static" } ], "correctAnswerIndex": 1 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "3. Each thread has its own call stack." } ], "values": { "options": [ { "type": "TEXT", "text": "A. True" }, { "type": "TEXT", "text": "B. False" } ], "correctAnswerIndex": 0 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "4. What occurs when two threads wait for each other forever?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. Race Condition" }, { "type": "TEXT", "text": "B. Fast processing" }, { "type": "TEXT", "text": "C. Deadlock" }, { "type": "TEXT", "text": "D. Memory Leak" } ], "correctAnswerIndex": 2 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "5. Marking a variable as 'volatile' ensures visibility across threads." } ], "values": { "options": [ { "type": "TEXT", "text": "A. True" }, { "type": "TEXT", "text": "B. False" } ], "correctAnswerIndex": 0 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "6. Which interface is preferred for defining a thread's task?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. Thread" }, { "type": "TEXT", "text": "B. Logic" }, { "type": "TEXT", "text": "C. Executable" }, { "type": "TEXT", "text": "D. Runnable" } ], "correctAnswerIndex": 3 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "7. What is the state of a thread that has finished executing?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. Terminated" }, { "type": "TEXT", "text": "B. New" }, { "type": "TEXT", "text": "C. Blocked" }, { "type": "TEXT", "text": "D. Ready" } ], "correctAnswerIndex": 0 } },

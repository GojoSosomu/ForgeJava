      "questions": [
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "1. What is the index of the first element in a Java array?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. 1" }, { "type": "TEXT", "text": "B. 0" } ], "correctAnswerIndex": 1 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "2. How do you access the length of an array named 'arr'?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. arr.size()" }, { "type": "TEXT", "text": "B. arr.count" }, { "type": "TEXT", "text": "C. arr.length" }, { "type": "TEXT", "text": "D. arr.total" } ], "correctAnswerIndex": 2 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "3. The size of an array can be changed after it is created." } ], "values": { "options": [ { "type": "TEXT", "text": "A. True" }, { "type": "TEXT", "text": "B. False" } ], "correctAnswerIndex": 1 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "4. What is the default value of an element in an int array?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. null" }, { "type": "TEXT", "text": "B. -1" }, { "type": "TEXT", "text": "C. 0" }, { "type": "TEXT", "text": "D. 1" } ], "correctAnswerIndex": 2 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "5. Which exception occurs if you access an invalid array index?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. IndexException" }, { "type": "TEXT", "text": "B. ArrayIndexOutOfBoundsException" }, { "type": "TEXT", "text": "C. NullPointerException" }, { "type": "TEXT", "text": "D. MemoryException" } ], "correctAnswerIndex": 1 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "6. A 2D array is essentially an array of arrays." } ], "values": { "options": [ { "type": "TEXT", "text": "A. True" }, { "type": "TEXT", "text": "B. False" } ], "correctAnswerIndex": 0 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "7. How do you create an array of 5 integers?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. int[] arr = new int[5];" }, { "type": "TEXT", "text": "B. int[5] arr;" }, { "type": "TEXT", "text": "C. array int(5);" }, { "type": "TEXT", "text": "D. int arr = new int(5);" } ], "correctAnswerIndex": 0 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "8. Which utility class provides sorting methods for arrays?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. java.util.Lists" }, { "type": "TEXT", "text": "B. java.util.Collections" }, { "type": "TEXT", "text": "C. java.util.Arrays" }, { "type": "TEXT", "text": "D. java.util.Sort" } ], "correctAnswerIndex": 2 } },

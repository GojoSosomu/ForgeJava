        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "10. Dynamic binding decides which method to run at ___?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. Compile time" }, { "type": "TEXT", "text": "B. Design time" }, { "type": "TEXT", "text": "C. Runtime" }, { "type": "TEXT", "text": "D. Compile-time only" } ], "correctAnswerIndex": 2 } }

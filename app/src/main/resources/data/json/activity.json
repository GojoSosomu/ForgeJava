        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "3. Which operator is used to check an object's type?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. isInstance" }, { "type": "TEXT", "text": "B. typeOf" }, { "type": "TEXT", "text": "C. instanceof" }, { "type": "TEXT", "text": "D. cast" } ], "correctAnswerIndex": 2 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "4. What is assigning a subclass object to a superclass reference?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. Upcasting" }, { "type": "TEXT", "text": "B. Downcasting" }, { "type": "TEXT", "text": "C. Crosscasting" }, { "type": "TEXT", "text": "D. Overriding" } ], "correctAnswerIndex": 0 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "5. Which annotation is used when overriding a parent method?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. @Override" }, { "type": "TEXT", "text": "B. @Overload" }, { "type": "TEXT", "text": "C. @Inherit" }, { "type": "TEXT", "text": "D. @Static" } ], "correctAnswerIndex": 0 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "6. Java supports multiple inheritance for classes (one child, many parents)." } ], "values": { "options": [ { "type": "TEXT", "text": "A. True" }, { "type": "TEXT", "text": "B. False" } ], "correctAnswerIndex": 1 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "7. What is the root class of all classes in Java?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. Base" }, { "type": "TEXT", "text": "B. Root" }, { "type": "TEXT", "text": "C. Java" }, { "type": "TEXT", "text": "D. Object" } ], "correctAnswerIndex": 3 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "8. Which keyword stops a class from being inherited?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. stop" }, { "type": "TEXT", "text": "B. final" }, { "type": "TEXT", "text": "C. static" }, { "type": "TEXT", "text": "D. private" } ], "correctAnswerIndex": 1 } },

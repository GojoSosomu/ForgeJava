{
  "A-001": {
    "problem": {
      "type": "QUESTIONNAIRE",
      "instructions": [
        { "type": "TEXT", "text": "Assessment 1: Environment & Architecture" }
      ],
      "questions": [
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "1. Which command is used to compile a Java file?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. java" }, { "type": "TEXT", "text": "B. javac" }, { "type": "TEXT", "text": "C. compile" }, { "type": "TEXT", "text": "D. build" } ], "correctAnswerIndex": 1 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "2. What is the extension of a compiled Java bytecode file?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. .java" }, { "type": "TEXT", "text": "B. .exe" }, { "type": "TEXT", "text": "C. .class" }, { "type": "TEXT", "text": "D. .bin" } ], "correctAnswerIndex": 2 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "3. Who is the primary creator of the Java language?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. James Gosling" }, { "type": "TEXT", "text": "B. Bjarne Stroustrup" }, { "type": "TEXT", "text": "C. Dennis Ritchie" }, { "type": "TEXT", "text": "D. Linus Torvalds" } ], "correctAnswerIndex": 0 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "4. What does JVM stand for?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. Java Variable Machine" }, { "type": "TEXT", "text": "B. Java Visual Model" }, { "type": "TEXT", "text": "C. Just Version Module" }, { "type": "TEXT", "text": "D. Java Virtual Machine" } ], "correctAnswerIndex": 3 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "5. Which component is required to develop (not just run) Java apps?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. JRE" }, { "type": "TEXT", "text": "B. JDK" }, { "type": "TEXT", "text": "C. JVM" }, { "type": "TEXT", "text": "D. Javadoc" } ], "correctAnswerIndex": 1 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "6. Bytecode is platform-specific instructions for Windows." } ], "values": { "options": [ { "type": "TEXT", "text": "A. True" }, { "type": "TEXT", "text": "B. False" } ], "correctAnswerIndex": 1 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "7. Where are objects stored in Java memory?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. Heap" }, { "type": "TEXT", "text": "B. Stack" }, { "type": "TEXT", "text": "C. Cache" }, { "type": "TEXT", "text": "D. Register" } ], "correctAnswerIndex": 0 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "8. Java's 'Write Once, Run Anywhere' is possible due to the JVM." } ], "values": { "options": [ { "type": "TEXT", "text": "A. True" }, { "type": "TEXT", "text": "B. False" } ], "correctAnswerIndex": 0 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "9. Which year was Java first released?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. 1991" }, { "type": "TEXT", "text": "B. 2000" }, { "type": "TEXT", "text": "C. 1995" }, { "type": "TEXT", "text": "D. 1985" } ], "correctAnswerIndex": 2 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "10. Which part of memory handles method execution and local variables?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. RAM" }, { "type": "TEXT", "text": "B. Heap" }, { "type": "TEXT", "text": "C. Drive" }, { "type": "TEXT", "text": "D. Stack" } ], "correctAnswerIndex": 3 } }
      ]
    }
  },
  "A-002": {
    "problem": {
      "type": "QUESTIONNAIRE",
      "instructions": [ { "type": "TEXT", "text": "Assessment 2: Data Types & Variables" } ],
      "questions": [
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "1. Which primitive type is used for high-precision decimals?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. double" }, { "type": "TEXT", "text": "B. float" }, { "type": "TEXT", "text": "C. long" }, { "type": "TEXT", "text": "D. int" } ], "correctAnswerIndex": 0 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "2. How many bits are in a standard 'int'?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. 16" }, { "type": "TEXT", "text": "B. 32" }, { "type": "TEXT", "text": "C. 64" }, { "type": "TEXT", "text": "D. 8" } ], "correctAnswerIndex": 1 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "3. Which keyword is used to declare a constant?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. static" }, { "type": "TEXT", "text": "B. const" }, { "type": "TEXT", "text": "C. final" }, { "type": "TEXT", "text": "D. fixed" } ], "correctAnswerIndex": 2 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "4. Which type is used for a single character?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. String" }, { "type": "TEXT", "text": "B. byte" }, { "type": "TEXT", "text": "C. text" }, { "type": "TEXT", "text": "D. char" } ], "correctAnswerIndex": 3 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "5. What is the default value of a boolean instance variable?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. false" }, { "type": "TEXT", "text": "B. true" }, { "type": "TEXT", "text": "C. null" }, { "type": "TEXT", "text": "D. 0" } ], "correctAnswerIndex": 0 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "6. Narrowing casting must be done manually by the programmer." } ], "values": { "options": [ { "type": "TEXT", "text": "A. True" }, { "type": "TEXT", "text": "B. False" } ], "correctAnswerIndex": 0 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "7. Which of these is a reference type, not a primitive?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. int" }, { "type": "TEXT", "text": "B. String" }, { "type": "TEXT", "text": "C. char" }, { "type": "TEXT", "text": "D. boolean" } ], "correctAnswerIndex": 1 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "8. What suffix is required for a float literal (e.g. 3.14)?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. L" }, { "type": "TEXT", "text": "B. D" }, { "type": "TEXT", "text": "C. F" }, { "type": "TEXT", "text": "D. S" } ], "correctAnswerIndex": 2 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "9. A 'short' variable can store larger numbers than a 'long'." } ], "values": { "options": [ { "type": "TEXT", "text": "A. True" }, { "type": "TEXT", "text": "B. False" } ], "correctAnswerIndex": 1 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "10. Which modifier makes a variable accessible only within its own class?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. public" }, { "type": "TEXT", "text": "B. protected" }, { "type": "TEXT", "text": "C. private" }, { "type": "TEXT", "text": "D. global" } ], "correctAnswerIndex": 2 } }
      ]
    }
  },
  "A-003": {
    "problem": {
      "type": "QUESTIONNAIRE",
      "instructions": [ { "type": "TEXT", "text": "Assessment 3: Operators & Logic" } ],
      "questions": [
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "1. What symbol is the modulus operator?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. %" }, { "type": "TEXT", "text": "B. /" }, { "type": "TEXT", "text": "C. &" }, { "type": "TEXT", "text": "D. #" } ], "correctAnswerIndex": 0 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "2. Which operator is used for Logical AND?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. ||" }, { "type": "TEXT", "text": "B. &&" }, { "type": "TEXT", "text": "C. &" }, { "type": "TEXT", "text": "D. !" } ], "correctAnswerIndex": 1 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "3. What is the result of 10 % 3?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. 3" }, { "type": "TEXT", "text": "B. 0" }, { "type": "TEXT", "text": "C. 1" }, { "type": "TEXT", "text": "D. 3.33" } ], "correctAnswerIndex": 2 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "4. Which symbol is the ternary operator?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. ->" }, { "type": "TEXT", "text": "B. ::" }, { "type": "TEXT", "text": "C. !=" }, { "type": "TEXT", "text": "D. ? :" } ], "correctAnswerIndex": 3 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "5. Java uses short-circuit evaluation for && and ||." } ], "values": { "options": [ { "type": "TEXT", "text": "A. True" }, { "type": "TEXT", "text": "B. False" } ], "correctAnswerIndex": 0 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "6. Which operator increments a value by 1?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. +=" }, { "type": "TEXT", "text": "B. ++" }, { "type": "TEXT", "text": "C. +" }, { "type": "TEXT", "text": "D. +1" } ], "correctAnswerIndex": 1 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "7. What is the result of '5 == 5'?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. 1" }, { "type": "TEXT", "text": "B. null" }, { "type": "TEXT", "text": "C. true" }, { "type": "TEXT", "text": "D. false" } ], "correctAnswerIndex": 2 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "8. Which operator has the highest precedence?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. *" }, { "type": "TEXT", "text": "B. +" }, { "type": "TEXT", "text": "C. &&" }, { "type": "TEXT", "text": "D. ()" } ], "correctAnswerIndex": 3 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "9. Shorthand x += 5 is the same as x = x + 5." } ], "values": { "options": [ { "type": "TEXT", "text": "A. True" }, { "type": "TEXT", "text": "B. False" } ], "correctAnswerIndex": 0 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "10. Which operator is used to compare if two objects are NOT equal?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. =!" }, { "type": "TEXT", "text": "B. !=" }, { "type": "TEXT", "text": "C. <>" }, { "type": "TEXT", "text": "D. NOT==" } ], "correctAnswerIndex": 1 } }
      ]
    }
  },
  "A-004": {
    "problem": {
      "type": "QUESTIONNAIRE",
      "instructions": [ { "type": "TEXT", "text": "Assessment 4: Control Flow" } ],
      "questions": [
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "1. Which keyword exits a loop immediately?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. break" }, { "type": "TEXT", "text": "B. continue" }, { "type": "TEXT", "text": "C. exit" }, { "type": "TEXT", "text": "D. stop" } ], "correctAnswerIndex": 0 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "2. Which loop is guaranteed to run at least once?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. for" }, { "type": "TEXT", "text": "B. do-while" }, { "type": "TEXT", "text": "C. while" }, { "type": "TEXT", "text": "D. foreach" } ], "correctAnswerIndex": 1 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "3. Which keyword skips the rest of the current loop iteration?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. next" }, { "type": "TEXT", "text": "B. break" }, { "type": "TEXT", "text": "C. continue" }, { "type": "TEXT", "text": "D. skip" } ], "correctAnswerIndex": 2 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "4. A switch statement can be used with double variables." } ], "values": { "options": [ { "type": "TEXT", "text": "A. True" }, { "type": "TEXT", "text": "B. False" } ], "correctAnswerIndex": 1 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "5. What happens if a 'break' is missing in a switch case?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. Compilation error" }, { "type": "TEXT", "text": "B. System crash" }, { "type": "TEXT", "text": "C. Infinite loop" }, { "type": "TEXT", "text": "D. Fall-through to the next case" } ], "correctAnswerIndex": 3 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "6. Which loop is typically used when the number of iterations is known?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. for" }, { "type": "TEXT", "text": "B. while" }, { "type": "TEXT", "text": "C. do-while" }, { "type": "TEXT", "text": "D. switch" } ], "correctAnswerIndex": 0 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "7. The 'else' block in an if-statement is mandatory." } ], "values": { "options": [ { "type": "TEXT", "text": "A. True" }, { "type": "TEXT", "text": "B. False" } ], "correctAnswerIndex": 1 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "8. What is the result of (5 > 2 && 3 < 1)?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. true" }, { "type": "TEXT", "text": "B. false" } ], "correctAnswerIndex": 1 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "9. Which block in a switch handles values not matched by cases?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. catch" }, { "type": "TEXT", "text": "B. else" }, { "type": "TEXT", "text": "C. default" }, { "type": "TEXT", "text": "D. finally" } ], "correctAnswerIndex": 2 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "10. In a for loop header, which part runs first and only once?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. Update" }, { "type": "TEXT", "text": "B. Condition" }, { "type": "TEXT", "text": "C. Initialization" }, { "type": "TEXT", "text": "D. Body" } ], "correctAnswerIndex": 2 } }
      ]
    }
  },
  "A-005": {
    "problem": {
      "type": "QUESTIONNAIRE",
      "instructions": [ { "type": "TEXT", "text": "Assessment 5: OOP Paradigm" } ],
      "questions": [
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "1. What is an instance of a class called?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. Method" }, { "type": "TEXT", "text": "B. Field" }, { "type": "TEXT", "text": "C. Object" }, { "type": "TEXT", "text": "D. Package" } ], "correctAnswerIndex": 2 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "2. Which keyword is used to create an object?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. create" }, { "type": "TEXT", "text": "B. new" }, { "type": "TEXT", "text": "C. build" }, { "type": "TEXT", "text": "D. spawn" } ], "correctAnswerIndex": 1 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "3. A Class is the blueprint for an Object." } ], "values": { "options": [ { "type": "TEXT", "text": "A. True" }, { "type": "TEXT", "text": "B. False" } ], "correctAnswerIndex": 0 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "4. Which keyword refers to the current object instance?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. super" }, { "type": "TEXT", "text": "B. that" }, { "type": "TEXT", "text": "C. current" }, { "type": "TEXT", "text": "D. this" } ], "correctAnswerIndex": 3 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "5. What defines the behavior of an object?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. Fields" }, { "type": "TEXT", "text": "B. Methods" }, { "type": "TEXT", "text": "C. Variables" }, { "type": "TEXT", "text": "D. Constructors" } ], "correctAnswerIndex": 1 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "6. Static members are shared by all instances of a class." } ], "values": { "options": [ { "type": "TEXT", "text": "A. True" }, { "type": "TEXT", "text": "B. False" } ], "correctAnswerIndex": 0 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "7. What defines the state of an object?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. Parameters" }, { "type": "TEXT", "text": "B. Packages" }, { "type": "TEXT", "text": "C. Fields" }, { "type": "TEXT", "text": "D. Loops" } ], "correctAnswerIndex": 2 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "8. Which keyword is used to define a category of objects?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. object" }, { "type": "TEXT", "text": "B. entity" }, { "type": "TEXT", "text": "C. type" }, { "type": "TEXT", "text": "D. class" } ], "correctAnswerIndex": 3 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "9. Where are objects created in memory?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. Stack" }, { "type": "TEXT", "text": "B. Heap" } ], "correctAnswerIndex": 1 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "10. Identity (==) and Equality (.equals) are the same thing for objects." } ], "values": { "options": [ { "type": "TEXT", "text": "A. True" }, { "type": "TEXT", "text": "B. False" } ], "correctAnswerIndex": 1 } }
      ]
    }
  },
  "A-006": {
    "problem": {
      "type": "QUESTIONNAIRE",
      "instructions": [ { "type": "TEXT", "text": "Assessment 6: Methods & Encapsulation" } ],
      "questions": [
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "1. What is the return type of a method that doesn't return data?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. null" }, { "type": "TEXT", "text": "B. void" }, { "type": "TEXT", "text": "C. none" }, { "type": "TEXT", "text": "D. empty" } ], "correctAnswerIndex": 1 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "2. Which keyword is used to send a value back from a method?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. give" }, { "type": "TEXT", "text": "B. send" }, { "type": "TEXT", "text": "C. result" }, { "type": "TEXT", "text": "D. return" } ], "correctAnswerIndex": 3 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "3. Encapsulation is achieved by making fields private." } ], "values": { "options": [ { "type": "TEXT", "text": "A. True" }, { "type": "TEXT", "text": "B. False" } ], "correctAnswerIndex": 0 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "4. Method overloading requires methods to have different signatures." } ], "values": { "options": [ { "type": "TEXT", "text": "A. True" }, { "type": "TEXT", "text": "B. False" } ], "correctAnswerIndex": 0 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "5. Which access modifier is the most restrictive?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. protected" }, { "type": "TEXT", "text": "B. private" }, { "type": "TEXT", "text": "C. public" }, { "type": "TEXT", "text": "D. default" } ], "correctAnswerIndex": 1 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "6. What is a public method that retrieves a private field value?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. Setter" }, { "type": "TEXT", "text": "B. Getter" }, { "type": "TEXT", "text": "C. Constructor" }, { "type": "TEXT", "text": "D. Adder" } ], "correctAnswerIndex": 1 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "7. Static methods can access instance variables directly." } ], "values": { "options": [ { "type": "TEXT", "text": "A. True" }, { "type": "TEXT", "text": "B. False" } ], "correctAnswerIndex": 1 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "8. What is the process of a method calling itself?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. Inheritance" }, { "type": "TEXT", "text": "B. Overloading" }, { "type": "TEXT", "text": "C. Recursion" }, { "type": "TEXT", "text": "D. Loopback" } ], "correctAnswerIndex": 2 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "9. Which modifier allows access within the same package but not outside?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. public" }, { "type": "TEXT", "text": "B. private" }, { "type": "TEXT", "text": "C. protected" }, { "type": "TEXT", "text": "D. default" } ], "correctAnswerIndex": 3 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "10. Parameters are variables defined in the method signature." } ], "values": { "options": [ { "type": "TEXT", "text": "A. True" }, { "type": "TEXT", "text": "B. False" } ], "correctAnswerIndex": 0 } }
      ]
    }
  },
  "A-007": {
    "problem": {
      "type": "QUESTIONNAIRE",
      "instructions": [ { "type": "TEXT", "text": "Assessment 7: Constructors & Lifecycle" } ],
      "questions": [
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "1. A constructor has a return type of void." } ], "values": { "options": [ { "type": "TEXT", "text": "A. True" }, { "type": "TEXT", "text": "B. False" } ], "correctAnswerIndex": 1 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "2. When is a constructor called?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. When a method runs" }, { "type": "TEXT", "text": "B. When a variable is deleted" }, { "type": "TEXT", "text": "C. When a class is defined" }, { "type": "TEXT", "text": "D. When an object is created" } ], "correctAnswerIndex": 3 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "3. The automatic constructor provided by Java is called the ___ constructor." } ], "values": { "options": [ { "type": "TEXT", "text": "A. static" }, { "type": "TEXT", "text": "B. final" }, { "type": "TEXT", "text": "C. default" }, { "type": "TEXT", "text": "D. basic" } ], "correctAnswerIndex": 2 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "4. Which system reclaims memory from unreachable objects?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. Garbage Collector" }, { "type": "TEXT", "text": "B. System Deletion" }, { "type": "TEXT", "text": "C. Heap Manager" }, { "type": "TEXT", "text": "D. Task Manager" } ], "correctAnswerIndex": 0 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "5. You can call another constructor in the same class using this()." } ], "values": { "options": [ { "type": "TEXT", "text": "A. True" }, { "type": "TEXT", "text": "B. False" } ], "correctAnswerIndex": 0 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "6. An object becomes eligible for garbage collection when it has no references." } ], "values": { "options": [ { "type": "TEXT", "text": "A. True" }, { "type": "TEXT", "text": "B. False" } ], "correctAnswerIndex": 0 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "7. What must the name of a constructor be?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. start" }, { "type": "TEXT", "text": "B. Init" }, { "type": "TEXT", "text": "C. The class name" }, { "type": "TEXT", "text": "D. main" } ], "correctAnswerIndex": 2 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "8. An object whose state cannot be changed after creation is ___." } ], "values": { "options": [ { "type": "TEXT", "text": "A. private" }, { "type": "TEXT", "text": "B. immutable" }, { "type": "TEXT", "text": "C. static" }, { "type": "TEXT", "text": "D. public" } ], "correctAnswerIndex": 1 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "9. If you define a custom constructor, Java still provides the default one." } ], "values": { "options": [ { "type": "TEXT", "text": "A. True" }, { "type": "TEXT", "text": "B. False" } ], "correctAnswerIndex": 1 } },
        { "type": "MULTIPLE_CHOICE", "question": [ { "type": "TEXT", "text": "10. Which keyword is used to call the parent class constructor?" } ], "values": { "options": [ { "type": "TEXT", "text": "A. parent" }, { "type": "TEXT", "text": "B. super" }, { "type": "TEXT", "text": "C. base" }, { "type": "TEXT", "text": "D. upper" } ], "correctAnswerIndex": 1 } }
